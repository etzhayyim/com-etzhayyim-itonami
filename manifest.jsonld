{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:itonami",
  "type": "Actor",
  "name": "itonami",
  "glyph": "営み",
  "purpose": "Factory-operations agent — the charter-clean inversion of an 'AI Factory Brain' / NVIDIA Factory Operations Blueprint (FOX). Observes the running line via kotoba-os scan-cycle Datoms (OEE / energy / quality) and RECOMMENDS improvement; never actuates the line and cannot represent per-worker monitoring.",
  "status": "R0-design-only",
  "tier": "B",
  "adr": "2606082300",
  "dependsOnAdr": ["2606031600", "2606013100", "2606034800", "2605311800", "2605312345", "2605215000", "2605241500"],
  "schema": ["00-contracts/schemas/itonami-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — scan-cycle observation = canonical state (kotoba-os: scan-cycle = Datom txn); methods/datom_emit.py emits canonical EAVT",
    "largeAssets": "DataLad → IPFS (80-data/itonami) — NO git-lfs",
    "inference": "Murakumo-only (ADR-2605215000) — narration of routed findings only",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy"
  },
  "integrates": ["actor:sarutahiko", "actor:giemon", "actor:manako", "actor:hikari", "actor:toritate"],
  "lineage": "the 'run the factory' observer paired with the 'build the factory' sims (giemon/sarutahiko/tatekata); consumes kotoba-os (ADR-2606031600) scan-cycle Datoms; quality findings route to manako vision (ADR-2606034800)",
  "cells": [
    {
      "id": "cell:itonami.analyze",
      "method": "methods/analyze.py",
      "input": "data/seed-factory-ops.kotoba.edn",
      "output": ["out/operations-report.md"],
      "pipeline": "load-edn → aggregate scan-cycle ticks per station → OEE (A×P×Q) + energy/good + idle-energy + scrap-rate → line rollup (gated by weakest station) → routed findings",
      "doc": "aggregate-first OEE / energy / quality; observe→recommend, never a write-back to the OT bus"
    },
    {
      "id": "cell:itonami.datom-emit",
      "method": "methods/datom_emit.py",
      "input": "data/seed-factory-ops.kotoba.edn",
      "output": ["out/itonami-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] (station + scan-cycle ticks, durable) + derived KPIs/findings flagged :bond/is-transient (computed on read, G3)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    },
    {
      "id": "cell:itonami.optimize",
      "method": "methods/optimize.py",
      "input": "data/seed-factory-ops.kotoba.edn",
      "output": ["out/optimization-proposals.md", "out/itonami-proposals.kotoba.edn"],
      "pipeline": "analyze → idle-powerdown (recoverable kWh × conservative fraction → line energy-reduction %) + bottleneck-relief (lift worst station to 2nd-worst → line OEE uplift) → transient proposal datoms",
      "doc": "R1 quantified improvement PROPOSALS (charter-clean form of the FOX 'cut 10% energy' lever); proposals-only, never a write-back (G1); efficiency not intensification (G2)"
    },
    {
      "id": "cell:itonami.inspect",
      "method": "methods/inspect.py",
      "input": ["data/seed-factory-ops.kotoba.edn", "data/seed-vision-detections.kotoba.edn"],
      "output": ["out/vision-inspection.md", "out/itonami-inspect.kotoba.edn"],
      "pipeline": "quality_target → manako inspection request (watch-classes, sample-rate, on-device/no-biometric constraints) + reconcile manako detections → defect-class Pareto + scan-cycle scrap cross-check → transient inspect datoms",
      "doc": "R2 vision-inspection hand-off (charter-clean form of the FOX 'vision-AI quality inspection' lever); object-only, never a person (manako ADR-2606034800); inspection INFORMS, never auto-rejects (G1)"
    },
    {
      "id": "cell:itonami.ingest",
      "method": "methods/ingest.py",
      "input": "data/seed-scancycle-stream.kotoba.edn",
      "output": ["out/ingested-ticks.kotoba.edn"],
      "pipeline": "parse recorded kotoba-os scan-cycle [e a v tx op] datoms → EAVT fold to scan-report entities → aggregate by (station,t) into interval ticks (Wh→kWh, cycles=good+scrap, state=most-severe) → :tick/* EDN that analyze/optimize/inspect consume",
      "doc": "R3 SCADA/OT scan-cycle ingest (charter-clean form of the FOX 'SCADA operating-data loop'); OFFLINE replay only — live OT socket is G6/Council-gated, no PLC write-back (G1), station/PLC scale rejects person attrs (G2)"
    },
    {
      "id": "cell:itonami.digest",
      "method": "methods/digest.py",
      "input": ["data/seed-factory-ops.kotoba.edn", "data/seed-vision-detections.kotoba.edn", "data/seed-ops-history.kotoba.edn"],
      "output": ["out/daily-digest.md", "out/itonami-digest.kotoba.edn"],
      "pipeline": "fuse analyze + optimize + inspect + plan (two-lens bottlenecks) + trend (multi-day drift, when history supplied) → one daily digest → Murakumo narration (LiteLLM loopback) with deterministic offline fallback → transient digest datoms",
      "doc": "R4 daily operations digest (charter-clean form of the FOX 'AI Factory Brain' daily report); Murakumo-only narration (G7, ADR-2605215000) — no external LLM, deterministic fallback when unreachable; recommends not actuates (G1), station-scale (G2)"
    },
    {
      "id": "cell:itonami.plan",
      "method": "methods/plan.py",
      "input": "data/seed-factory-ops.kotoba.edn",
      "output": ["out/throughput-plan.md", "out/itonami-plan.kotoba.edn"],
      "pipeline": "per-station takt-capacity (uptime÷takt) → line throughput bottleneck (distinct from the OEE bottleneck) → units/day (documented operating-hours) → availability-recovery relief plan with quantified uplift",
      "doc": "R5 throughput / line-balance plan; translates OEE into units/day through the takt-capacity lens (the throughput-worst station often differs from the OEE-worst); relief is availability recovery within takt (G2), plan-not-actuate (G1), documented hours (G5)"
    },
    {
      "id": "cell:itonami.trend",
      "method": "methods/trend.py",
      "input": "data/seed-ops-history.kotoba.edn",
      "output": ["out/trend-report.md", "out/itonami-trends.kotoba.edn"],
      "pipeline": "load durable daily :opsday/* snapshots (as-of series) → per (scope, KPI) first/last + least-squares slope + polarity-aware direction {improving/flat/degrading} → regression attention list",
      "doc": "R7 KPI trend / drift detector; tracks trajectories (kotoba as-of history; Wellbecoming = trajectory not snapshot) to surface slow OEE decline / scrap creep before any single day alarms; recommend-not-actuate (G1), line/station scope only — no worker trajectory (G2), directions transient (G3)"
    },
    {
      "id": "cell:itonami.alert",
      "method": "methods/alert.py",
      "input": "data/seed-factory-ops.kotoba.edn",
      "output": ["out/alerts.md", "out/itonami-alerts.kotoba.edn"],
      "pipeline": "compare each line/station KPI to documented (warn, critical) thresholds (polarity-aware) → graded {warn/critical} advisory alert list → transient alert datoms",
      "doc": "R9 operational threshold alerts — the HMI alarm half, ADVISORY ONLY (G1): raises a flag for a human/Council, NEVER halts the line / trips an e-stop / writes to the OT bus (safety interlocks live in the PLC, not here; no actuation token is representable). Thresholds are documented config (G5), station/line scope (G2)"
    },
    {
      "id": "cell:itonami.fleet",
      "method": "methods/fleet.py",
      "input": "data/seed-fleet-ops.kotoba.edn",
      "output": ["out/fleet-rollup.md", "out/itonami-fleet.kotoba.edn"],
      "pipeline": "group stations by :station/line → per-line analyze + alert.evaluate → plant rollup (per-line OEE/energy/scrap + alert counts) → rank lines worst-first (critical alerts, then lowest OEE)",
      "doc": "R10 multi-line FLEET rollup — the whole-plant scope (a plant brain oversees >1 line); recommends which line to attend first, never actuates (G1); ranks LINES, never people — no worker dimension (G2); per-line KPIs transient (G3)"
    }
  ],
  "gates": {
    "G1": "OBSERVE → RECOMMEND only. itonami NEVER actuates the line — no-server-key, liveActuation:false (consistent with kotoba-os C-carve-outs). Optimization is a proposal to a human / Council, never a write back to the OT bus.",
    "G2": "STATION / LINE scale ONLY. No :worker/* or :person/* dimension exists or is permitted; per-person productivity / pace / presence is structurally unrepresentable (Wellbecoming §1.13, anti-labor-surveillance). Efficiency/energy/quality gains route to IMPROVEMENT, never to line-speed-up or labor intensification.",
    "G3": "non-adjudicating. Station states (:run/:idle/:down) and counts are DISCLOSED scan-cycle facts; KPIs are read-time aggregates flagged :bond/is-transient, never durable itonami verdicts.",
    "G4": "civilian producing actors ONLY (sarutahiko/giemon/tatekata/hikari/mitsuho/mizuho line ops). Weapons / kinetic-military line control is unrepresentable (Charter §1.12).",
    "G5": "sourcing honesty — every record :authoritative | :representative; R0 seed is :representative synthetic data, never presented as live OT.",
    "G6": "outward-gated — live OT/SCADA ingest (Modbus/OPC-UA/EtherCAT via kotoba-os device worlds) requires Council + operator DID; R0 = analyzer + schema + seed only.",
    "G7": "Murakumo-only narration (ADR-2605215000) — no external LLM for finding narration."
  }
}
